# .env
# Used for interpolation in compose.yml files
# Global variables for the entire project
# Prevents hard-coding values in Dockerfiles and compose files
# Takes precedence over specific service env-files

USER_LOGIN="dbarba-v"
DOMAIN_NAME="${USER_LOGIN}.42.fr"

# Networks
# Frontend network that connects nginx <-> internet and nginx <-> php-fpm
FRONTEND="frontend_net"
FRONTEND_SUBNET=172.18.0.0/28
FRONTEND_GATEWAY=172.18.0.1
FRONTEND_NGINX_IP=172.18.0.2
FRONTEND_PHP_FPM_IP=172.18.0.3
# Backend network that connects php-fpm <-> mariadb
BACKEND="backend_net"
BACKEND_SUBNET=172.18.0.16/28
BACKEND_GATEWAY=172.18.17.1
BACKEND_PHP_FPM_IP=172.18.0.18
BACKEND_MARIADB_IP=172.18.0.19

# Volumes
DB_VOL_NAME="database_data"
DB_VOL_MOUNTPOINT="/var/lib/mysql"
DB_VOL_DEVICE_PATH="/home/${USER_LOGIN}/data/mariadb" # Confirm if can be set to name of volume
WP_VOL_NAME="wordpress_data"
WP_VOL_MOUNTPOINT="/var/www/${DOMAIN_NAME}"
WP_VOL_DEVICE_PATH="/home/${USER_LOGIN}/data/wordpress" # Confirm if can be set to name of volume

# MariaDB
MARIADB_BUILD_CONTEXT="."
MARIADB_DOCKERFILE="Dockerfile"
MARIADB_IMAGE_REPO="mariadb"
MARIADB_IMAGE_TAG="inception"
MARIADB_CONTAINER_NAME="mariadb"

MARIADB_CONFIG_ENV="config.env" # On config.env go fixed configs
MARIADB_ROOT_PASS=## SECRET
MARIADB_ADMIN="mdbadmin"
MARIADB_ADMIN_PASS=## SECRET
MARIADB_CHARSET="utf8mb4"
MARIADB_COLLATION="utf8mb4_unicode_ci"
MARIADB_WPDB_NAME="wpdatabase"
MARIADB_WPDB_ADMIN="wpdbadmin"
MARIADB_WPDB_ADMIN_PASS=## SECRET
MARIADB_WPDB_CHARSET="utf8mb4"
MARIADB_WPDB_COLLATION="utf8mb4_unicode_ci"
MARIADB_PORT=3306

# WordPress-PHP-FPM
WORDPRESS_BUILD_CONTEXT="."
WORDPRESS_DOCKERFILE="Dockerfile"
WORDPRESS_IMAGE_REPO="wordpress-php"
WORDPRESS_IMAGE_TAG="inception"
WORDPRESS_CONTAINER_NAME="wordpress-php"

WORDPRESS_CONFIG_ENV="config.env"
PHPFPM_PORT=9000
PHPFPM_USER=# Need info, used in php-fpm.conf, nginx default
NGINX="${NGINX_CONTAINER_NAME}"
NGINX_PORT="${NGINX_PHP_PORT}" # 9000
DB_HOST="${MARIADB_CONTAINER_NAME}"
DB_PORT=3306
DB_NAME="${MARIADB_WPDB_NAME}"
DB_USER="${MARIADB_WPDB_ADMIN}"
DB_USER_PASS=## SECRET
WP_USERS_CREATE="owner:administrator:owner@mail.com,demo:editor:demo@mail.com" # username:role:mail
WP_PATH="/var/www/${DOMAIN_NAME}" # Same as WP_VOL_MOUNTPOINT

# NGINX
NGINX_BUILD_CONTEXT="."
NGINX_DOCKERFILE="Dockerfile"
NGINX_IMAGE_REPO="nginx"
NGINX_IMAGE_TAG="inception"
NGINX_CONTAINER_NAME="nginx"

NGINX_CONFIG_ENV="config.env"
HOST_PORT=443
OUTSIDE_PORT=443
CGI_HOST=${WORDPRESS_CONTAINER_NAME}
CGI_PORT=${PHPFPM_PORT}
WEB_DATA="/var/www" # Maybe /var/www/${DOMAIN_NAME} if only one site
SSL_KEY="${DOMAIN_NAME}.key"
SSL_KEY_PATH="/etc/ssl/private" # Path to SSL key
SSL_CERT="${DOMAIN_NAME}.cert"
SSL_CERT_PATH="/etc/ssl/cert" # Path to SSL certificate

