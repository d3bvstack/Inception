# .env
# Used for interpolation in compose.yml files
# Global variables for the entire project
# Prevents hard-coding values in Dockerfiles and compose files
# Takes precedence over specific service env-files

USER_LOGIN="dbarba-v"
DOMAIN_NAME="${USER_LOGIN}.42.fr"

# Networks
# Frontend network that connects nginx <-> internet and nginx <-> php-fpm
NETWORK_FRONTEND_NAME="frontend_net"
NETWORK_FRONTEND_SUBNET=172.18.0.0/28
NETWORK_FRONTEND_GATEWAY=172.18.0.1
NETWORK_FRONTEND_NGINX_IP=172.18.0.2
NETWORK_FRONTEND_PHPFPM_IP=172.18.0.3
# Backend network that connects php-fpm <-> mariadb
NETWORK_BACKEND_NAME="backend_net"
NETWORK_BACKEND_SUBNET=172.18.0.16/28
NETWORK_BACKEND_GATEWAY=172.18.0.17
NETWORK_BACKEND_PHPFPM_IP=172.18.0.18
NETWORK_BACKEND_DB_IP=172.18.0.19

# Volumes
VOLUME_DB_NAME="database_data"
VOLUME_DB_MOUNTPOINT="/var/lib/mysql"
VOLUME_DB_HOST_PATH="/home/${USER_LOGIN}/data/mariadb"
VOLUME_WP_NAME="wordpress_data"
VOLUME_WP_MOUNTPOINT="/var/www/${DOMAIN_NAME}"
VOLUME_WP_HOST_PATH="/home/${USER_LOGIN}/data/wordpress"

# MariaDB
MDB_BUILD_CONTEXT="."
MDB_DOCKERFILE="Dockerfile"
MDB_IMAGE_REPO="mariadb"
MDB_IMAGE_TAG="inception"
MDB_CONTAINER_NAME="mariadb"

MDB_CONFIG_ENV="config.env" # On config.env go fixed configs
MDB_ROOT_PASSWORD=## SECRET
MDB_ADMIN="mdbadmin"
MDB_ADMIN_PASSWORD=## SECRET
MDB_CHARSET="utf8mb4"
MDB_COLLATION="utf8mb4_unicode_ci"
MDB_ENGINE_PORT=3306

# MariaDB - WordPress DB
WP_DB_NAME="wpdatabase"
WP_DB_ADMIN="wpdbadmin"
WP_DB_ADMIN_PASSWORD=## SECRET
WP_DB_CHARSET="utf8mb4"
WP_DB_COLLATION="utf8mb4_unicode_ci"

# WordPress - PHP-FPM
WP_BUILD_CONTEXT="."
WP_DOCKERFILE="Dockerfile"
WP_IMAGE_REPO="wordpress-php"
WP_IMAGE_TAG="inception"
WP_CONTAINER_NAME="wordpress-php"

WP_CONFIG_ENV="config.env"
PHPFPM_LISTEN_PORT=9000
PHPFPM_USER=# Need info, used in php-fpm.conf, nginx default, don't know if www-data or nginx
PHP_FPM_VERSION="8.2"
NGINX="${NGINX_CONTAINER_NAME}"
NGINX_PORT="${NGINX_PHP_PORT}" # 9000
DB_HOST="${MARIADB_CONTAINER_NAME}"
DB_SERVICE_PORT=3306
DB_NAME="${MARIADB_WPDB_NAME}"
DB_USER="${MARIADB_WPDB_ADMIN}"
DB_USER_PASSWORD=## SECRET
WP_USERS_CREATE="owner:administrator:owner@mail.com,demo:editor:demo@mail.com" # username:role:mail
WP_WEBROOT="/var/www/${DOMAIN_NAME}" # Same as WP_VOL_MOUNTPOINT

# NGINX
NGINX_BUILD_CONTEXT="."
NGINX_DOCKERFILE="Dockerfile"
NGINX_IMAGE_REPO="nginx"
NGINX_IMAGE_TAG="inception"
NGINX_CONTAINER_NAME="nginx"

NGINX_CONFIG_ENV="config.env"
NGINX_HOST_PORT=443
NGINX_LISTEN_PORT=443
NGINX_PHP_SERVICE=${WORDPRESS_CONTAINER_NAME}
NGINX_PHP_SERVICE_PORT=${PHPFPM_PORT}
WEB_DATA="/var/www" # Maybe /var/www/${DOMAIN_NAME} if only one site

KEY_NAME="${DOMAIN_NAME}.key"
KEY_PATH="/etc/ssl/private" # Path to SSL key
CERT_NAME="${DOMAIN_NAME}.cert"
CERT_PATH="/etc/ssl/cert" # Path to SSL certificate

# Image naming
DB_IMAGE_NAME="${DB_IMAGE_REPO}:${DB_IMAGE_TAG}"
WP_IMAGE_NAME="${WP_IMAGE_REPO}:${WP_IMAGE_TAG}"
NGINX_IMAGE_NAME="${NGINX_IMAGE_REPO}:${NGINX_IMAGE_TAG}"